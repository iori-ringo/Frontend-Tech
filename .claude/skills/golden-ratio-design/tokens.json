{
  "$schema": "Golden Ratio Design Tokens derived from φ = 1.618",
  "constants": {
    "phi": 1.618,
    "halfstep": 1.272,
    "quarterstep": 1.128,
    "eighthstep": 1.062
  },
  "spacing": {
    "phi-3xs": { "rem": "0.236rem", "px": 3.78, "exponent": -3, "tailwind": "p-phi-3xs | m-phi-3xs | gap-phi-3xs" },
    "phi-2xs": { "rem": "0.382rem", "px": 6.11, "exponent": -2, "tailwind": "p-phi-2xs | m-phi-2xs | gap-phi-2xs" },
    "phi-sm":  { "rem": "0.618rem", "px": 9.89, "exponent": -1, "tailwind": "p-phi-sm | m-phi-sm | gap-phi-sm" },
    "phi-md":  { "rem": "1.000rem", "px": 16.00, "exponent": 0, "tailwind": "p-phi-md | m-phi-md | gap-phi-md" },
    "phi-lg":  { "rem": "1.618rem", "px": 25.89, "exponent": 1, "tailwind": "p-phi-lg | m-phi-lg | gap-phi-lg" },
    "phi-xl":  { "rem": "2.618rem", "px": 41.89, "exponent": 2, "tailwind": "p-phi-xl | m-phi-xl | gap-phi-xl" },
    "phi-2xl": { "rem": "4.236rem", "px": 67.77, "exponent": 3, "tailwind": "p-phi-2xl | m-phi-2xl | gap-phi-2xl" },
    "phi-3xl": { "rem": "6.854rem", "px": 109.66, "exponent": 4, "tailwind": "p-phi-3xl | m-phi-3xl | gap-phi-3xl" },
    "phi-4xl": { "rem": "11.089rem", "px": 177.42, "exponent": 5, "tailwind": "p-phi-4xl | m-phi-4xl | gap-phi-4xl" }
  },
  "typography": {
    "display1":   { "fontSize": "4.236rem", "pxSize": 67.8,  "lineHeight": 1.128, "lineHeightName": "quarterstep", "formula": "φ³" },
    "display2":   { "fontSize": "2.618rem", "pxSize": 41.9,  "lineHeight": 1.272, "lineHeightName": "halfstep",    "formula": "φ²" },
    "title1":     { "fontSize": "2.058rem", "pxSize": 32.9,  "lineHeight": 1.272, "lineHeightName": "halfstep",    "formula": "φ × √φ" },
    "title2":     { "fontSize": "1.618rem", "pxSize": 25.9,  "lineHeight": 1.272, "lineHeightName": "halfstep",    "formula": "φ" },
    "title3":     { "fontSize": "1.272rem", "pxSize": 20.4,  "lineHeight": 1.272, "lineHeightName": "halfstep",    "formula": "√φ" },
    "heading":    { "fontSize": "1.128rem", "pxSize": 18.0,  "lineHeight": 1.272, "lineHeightName": "halfstep",    "formula": "⁴√φ" },
    "body":       { "fontSize": "1.000rem", "pxSize": 16.0,  "lineHeight": 1.618, "lineHeightName": "phi",         "formula": "1" },
    "subheading": { "fontSize": "0.887rem", "pxSize": 14.2,  "lineHeight": 1.272, "lineHeightName": "halfstep",    "formula": "1 / ⁴√φ" },
    "callout":    { "fontSize": "0.942rem", "pxSize": 15.1,  "lineHeight": 1.272, "lineHeightName": "halfstep",    "formula": "1 / ⁸√φ" },
    "label":      { "fontSize": "0.835rem", "pxSize": 13.4,  "lineHeight": 1.272, "lineHeightName": "halfstep",    "formula": "1 / (⁴√φ × ⁸√φ)" },
    "caption":    { "fontSize": "0.786rem", "pxSize": 12.6,  "lineHeight": 1.272, "lineHeightName": "halfstep",    "formula": "1 / √φ" }
  },
  "lineHeight": {
    "phi":         { "value": 1.618, "use": "body text, paragraphs" },
    "phi-half":    { "value": 1.272, "use": "headings, titles, UI elements" },
    "phi-quarter": { "value": 1.128, "use": "large display text" },
    "phi-tight":   { "value": 1.062, "use": "compact labels, badges" }
  },
  "borderRadius": {
    "phi-3xs": { "rem": "0.236rem", "px": 3.78 },
    "phi-2xs": { "rem": "0.382rem", "px": 6.11 },
    "phi-sm":  { "rem": "0.618rem", "px": 9.89 },
    "phi-md":  { "rem": "1.000rem", "px": 16.00 },
    "phi-lg":  { "rem": "1.618rem", "px": 25.89 },
    "phi-xl":  { "rem": "2.618rem", "px": 41.89 }
  },
  "relationships": {
    "padding_to_fontSize": "same step or one step below on the φ scale",
    "borderRadius_to_padding": "same step or below on the φ scale",
    "nestedRadius": "inner-radius = outer-radius - outer-padding",
    "gap_to_padding": "one step below the padding on the φ scale",
    "iconPadding": "reduce padding on icon side by one φ step"
  }
}
